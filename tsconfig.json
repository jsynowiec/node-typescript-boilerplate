{
  "compilerOptions": {
    "target": "ES2024",
    "module": "nodenext",
    "lib": ["ES2024"],
    "types": ["node"],
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "outDir": "build",
    // set declaration to `false` for an app, keep `true` for a library
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "alwaysStrict": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "strict": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
  },
  "include": ["src"],
}
